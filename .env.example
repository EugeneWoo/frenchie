# ElevenLabs Text-to-Speech API
# Required for POST /api/tts — French audio playback
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# ElevenLabs Scribe STT — same key as TTS above, no extra credential needed
# POST /api/transcribe uses ELEVENLABS_API_KEY automatically

# Google Gemini API
# Required for POST /api/evaluate and POST /api/generate-questions
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — set to your frontend origin in production (e.g. https://frenchie.up.railway.app)
# In development, leave unset or set to http://localhost:3000 to allow all origins
FRONTEND_ORIGIN=http://localhost:3000

# Server port — Railway sets this automatically; override locally if needed
PORT=3000
